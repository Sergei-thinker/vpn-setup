# === Main VPS (Layer 0) ===
VPN_HOST=<YOUR_VPS_IP>
VPN_SSH_PORT=22
VPN_SSH_USER=root
VPN_SSH_KEY=~/.ssh/id_ed25519
# VPN_SSH_PASS=  # Only if not using SSH keys

# === Russian Relay VPS (Layer 1, optional) ===
# Generic RU VPS: Timeweb Cloud, VDSina, Selectel, VK Cloud и т. п.
# NB: Yandex Cloud не обходит белые списки ТСПУ (AS Yandex.Cloud LLC != AS YANDEX LLC).
# Подробности — docs/07-advanced-layers.md UPDATE 2026-04-17.
RELAY_HOST=
RELAY_SSH_PORT=22
RELAY_SSH_USER=root
RELAY_SSH_KEY=~/.ssh/id_ed25519
# RELAY_SSH_PASS=
# Provider: timeweb | vdsina | selectel | vk | generic
RELAY_PROVIDER=generic

# === Cross-VPS references ===
SWEDEN_VPS_IP=<YOUR_VPS_IP>

# === Main VPS relay inbound (Layer 1 outbound target) ===
SWEDEN_RELAY_PORT=10443
SWEDEN_RELAY_UUID=
SWEDEN_RELAY_PUBKEY=
SWEDEN_RELAY_SID=
