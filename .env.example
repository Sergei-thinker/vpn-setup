# ============================================================
# VPN Infrastructure — Environment Configuration
# ============================================================
# Скопируйте этот файл: cp .env.example .env
# Заполните ОБЯЗАТЕЛЬНЫЕ поля перед запуском деплоя.
# НЕ коммитьте .env в git!
# ============================================================

# === Swedish VPS (Layer 0 — ОБЯЗАТЕЛЬНО) ====================
# Это ваш основной VPN-сервер за рубежом.
# Получите эти данные у хостинг-провайдера после аренды VPS.

# IP-адрес вашего VPS (обязательно)
VPN_HOST=

# SSH-порт (по умолчанию 22, но quick-rebuild.sh сменит на 49152,
# потому что ТСПУ блокирует порт 22 к зарубежным IP)
VPN_SSH_PORT=49152

# SSH-пользователь (обычно root для нового VPS)
VPN_SSH_USER=root

# Путь к SSH-ключу (рекомендуется). Если ключа нет — см. VPN_SSH_PASS ниже.
# Сгенерировать ключ: ssh-keygen -t ed25519
VPN_SSH_KEY=~/.ssh/id_ed25519

# SSH-пароль (только если НЕ используете SSH-ключ).
# Раскомментируйте и заполните:
# VPN_SSH_PASS=your_password_here

# === Russian Relay VPS (Layer 1 — ОПЦИОНАЛЬНО) ==============
# Нужен только если Layer 0 заблокирован (мобильная сеть с белыми списками,
# IP VPS в чёрном списке). Можно пропустить при первой установке.

# IP-адрес российского relay-сервера
RELAY_HOST=

# SSH-порт relay (обычно 22, т.к. внутри РФ не блокируется)
RELAY_SSH_PORT=22

# SSH-пользователь relay
RELAY_SSH_USER=root

# Путь к SSH-ключу relay
RELAY_SSH_KEY=~/.ssh/id_ed25519

# SSH-пароль relay (только если НЕ используете ключ)
# RELAY_SSH_PASS=

# Провайдер relay: yandex | vk | timeweb | vdsina | generic
# yandex — рекомендуется (IP Yandex Cloud в белых списках ТСПУ)
RELAY_PROVIDER=yandex

# === Yandex Cloud (только для RELAY_PROVIDER=yandex) ========
# Нужен yc CLI: https://cloud.yandex.ru/docs/cli/quickstart
# Установить: curl -sSL https://storage.yandexcloud.net/yandexcloud-yc/install.sh | bash

# ID каталога в Yandex Cloud (найти: yc resource-manager folder list)
YC_FOLDER_ID=

# Зона размещения VM (ru-central1-a/b/d)
YC_ZONE=ru-central1-a

# Имя VM в Yandex Cloud
YC_VM_NAME=vpn-relay

# Preemptible VM — в ~3 раза дешевле, но перезапускается каждые 24ч.
# rotate-relay-yc.sh автоматически рестартует VM по cron.
YC_PREEMPTIBLE=true

# Путь к публичному SSH-ключу для VM
YC_SSH_KEY_PUB=~/.ssh/id_ed25519.pub

# === Cross-VPS references (Layer 1) ========================
# IP шведского VPS — используется relay-скриптами для настройки маршрута.
# Совпадает с VPN_HOST, но задаётся отдельно для cloud-init шаблона.
SWEDEN_VPS_IP=

# === Sweden relay inbound (Layer 1 — генерируется автоматически) ===
# Эти значения выведет deploy-relay-sweden.sh после запуска.
# Скопируйте их сюда перед запуском deploy-relay-yc.sh.

# Порт xHTTP inbound на шведском VPS
SWEDEN_RELAY_PORT=10443

# UUID для relay-подключения (формат: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
SWEDEN_RELAY_UUID=

# Публичный ключ Reality (base64, ~43 символа)
SWEDEN_RELAY_PUBKEY=

# Short ID (8 hex символов, например: abcd1234)
SWEDEN_RELAY_SID=
