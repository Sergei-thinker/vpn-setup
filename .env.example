# === Main VPS (Layer 0) ===
VPN_HOST=<YOUR_VPS_IP>
VPN_SSH_PORT=22
VPN_SSH_USER=root
VPN_SSH_KEY=~/.ssh/id_ed25519
# VPN_SSH_PASS=  # Only if not using SSH keys

# === Russian Relay VPS (Layer 1) ===
RELAY_HOST=
RELAY_SSH_PORT=22
RELAY_SSH_USER=root
RELAY_SSH_KEY=~/.ssh/id_ed25519
# RELAY_SSH_PASS=
# Provider: yandex | vk | timeweb | vdsina | generic
RELAY_PROVIDER=yandex

# === Yandex Cloud (for RELAY_PROVIDER=yandex) ===
YC_FOLDER_ID=
YC_ZONE=ru-central1-a
YC_VM_NAME=vpn-relay
YC_PREEMPTIBLE=true
YC_SSH_KEY_PUB=~/.ssh/id_ed25519.pub

# === Cross-VPS references ===
SWEDEN_VPS_IP=<YOUR_VPS_IP>

# === Sweden relay inbound (Layer 1 outbound target) ===
SWEDEN_RELAY_PORT=10443
SWEDEN_RELAY_UUID=
SWEDEN_RELAY_PUBKEY=
SWEDEN_RELAY_SID=
